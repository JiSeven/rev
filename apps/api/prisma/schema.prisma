generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PartCategory {
  ENGINE
  BRAKES
  SUSPENSION
  EXHAUST
  ELECTRICAL
  BODY
  DRIVETRAIN
  TYRES
  ACCESSORIES
}

model Motorcycle {
  id            String   @id @default(uuid())
  name          String
  description   String
  make          String
  model         String
  year          Int
  priceAmount   Float
  priceCurrency String   @db.Char(3)
  engineSpec    Json
  createdAt     DateTime @default(now())

  @@unique([make, model, year])
  @@index([make])
  @@index([createdAt(sort: Desc)])
}

model Part {
  id              String       @id @default(uuid())
  name            String
  description     String
  make            String
  model           String
  year            Int
  priceAmount     Float
  priceCurrency   String       @db.Char(3)
  partCategory    PartCategory
  compatibilities Json
  oemPartNumber   String?
  createdAt       DateTime     @default(now())

  @@index([partCategory])
  @@index([createdAt(sort: Desc)])
}
