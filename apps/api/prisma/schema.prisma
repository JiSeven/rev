generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model BodyType {
  id String @id @default(cuid())
  name String @unique

  vehicles Vehicle[]

  @@map("body_types")
}

model FuelType {
  id String @id @default(cuid())
  name String @unique

  vehicles Vehicle[]

  @@map("fuel_types")
}

model TransmissionType {
  id String @id @default(cuid())
  name String @unique

  vehicles Vehicle[]

  @@map("transmission_types")
}

model Vehicle {
  id String @id @default(cuid())
  vin String @unique @db.VarChar(17)
  plateNumber String @unique @db.VarChar(15)
  year Int @db.SmallInt
  isAvailable Boolean @default(true)
  fuelLevel Int @default(100) @db.SmallInt

  latitude Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)

  bodyTypeId String
  fuelTypeId String
  transmissionTypeId String

  bodyType BodyType @relation(fields: [bodyTypeId], references: [id])
  fuelType FuelType @relation(fields: [fuelTypeId], references: [id])
  transmissionType TransmissionType @relation(fields: [transmissionTypeId], references: [id])

  @@map("vehicles")
}

