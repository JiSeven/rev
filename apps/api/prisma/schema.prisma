generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id String @id @default(cuid())
  name String @unique

  models Model[]

  @@map("brands")
}

model Model {
  id String @id @default(cuid())
  name String 

  brandId String
  brand Brand @relation(fields: [brandId], references: [id])

  vehicles Vehicle[]

  @@map("models")
}

model Vehicle {
  id String @id @default(cuid())

  modelId String
  model Model @relation(fields: [modelId], references: [id])
  
  @@map("vehicles")
}

